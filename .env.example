# ─────────────────────────────────────────────────────────────
#  Memos by MelvinOS — example environment
#  Copy this to .env and fill in the values.
#
#  Generate secrets:
#    SESSION_SECRET / ENCRYPTION_KEY:  openssl rand -hex 32
#    POSTGRES_PASSWORD:                openssl rand -hex 24
# ─────────────────────────────────────────────────────────────

# ── Version & project ───────────────────────────────────────
APP_VERSION=dev                # set to e.g. 0.1.0 to pin a GHCR image tag
COMPOSE_PROJECT_NAME=memos

# ── Required secrets ────────────────────────────────────────
POSTGRES_PASSWORD=change_me_postgres_password
SESSION_SECRET=change_me_session_secret_32_bytes_hex
ENCRYPTION_KEY=change_me_encryption_key_32_bytes_hex

# ── Default user (seeded on first boot) ─────────────────────
MEMOS_DEFAULT_EMAIL=admin@example.com
MEMOS_DEFAULT_NAME=Admin
# Set to seed a password for the default user on first boot.
# Unset (or change it) once you've signed in and rotated the password.
MEMOS_DEMO_PASSWORD=memosdemo2026

# Set to 1 to bypass the login screen entirely (LAN / behind-auth-proxy deployments).
MEMOS_SINGLE_USER=

# ── Networking ──────────────────────────────────────────────
HOST_PORT=3100
APP_BASE_URL=http://localhost:3100
# Set to 1 if running behind a reverse proxy (Caddy/nginx) with HTTPS.
TRUST_PROXY=0

# ── Branding (whitelabel) ───────────────────────────────────
BRAND_NAME=Memos
BRAND_SHORT=Memos
BRAND_TAGLINE=by MelvinOS
BRAND_PRIMARY_HSL=217 91% 60%
BRAND_ACCENT_HSL=262 83% 70%
BRAND_SUPPORT_EMAIL=
BRAND_LOGO_URL=
BRAND_FAVICON_URL=
BRAND_PRODUCT_URL=https://melvinos.com
BRAND_POWERED_BY=MelvinOS
BRAND_HIDE_POWERED_BY=0

# ── Optional fallbacks (normally set in-app at /settings) ───
GROQ_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
NOTION_API_KEY=
