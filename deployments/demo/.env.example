# ─────────────────────────────────────────────────────────────
#  Memos — DEMO deployment
#  Public-facing demo instance. Seeded with a demo user.
#  Sign in with the credentials below.
# ─────────────────────────────────────────────────────────────

# Pinned to a released version for stability
APP_VERSION=latest
COMPOSE_PROJECT_NAME=memos-demo

# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=replace_me_demo_pg
# Generate: openssl rand -hex 32
SESSION_SECRET=replace_me_demo_session_secret_32b
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace_me_demo_encryption_key_32b

# Demo user (seeded on first boot)
MEMOS_DEFAULT_EMAIL=demo@memos.app
MEMOS_DEFAULT_NAME=Demo User
MEMOS_DEMO_PASSWORD=memosdemo

# Public URL / port
HOST_PORT=3100
APP_BASE_URL=https://demo.memos.app
TRUST_PROXY=1

# Branding — keep default Memos branding for the demo
BRAND_NAME=Memos
BRAND_SHORT=Memos
BRAND_TAGLINE=by MelvinOS — Demo
BRAND_POWERED_BY=MelvinOS
BRAND_PRODUCT_URL=https://melvinos.com
